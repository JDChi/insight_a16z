---
interface Props {
  title: string;
  intro?: string;
  meta?: string[];
}

const { title, intro, meta = [] } = Astro.props;
---

<section class="container content-shell">
  <div class="content-main panel">
    <div class="content-header">
      <div class="eyebrow">Insight Article</div>
      <h1>{title}</h1>
      {intro && <p>{intro}</p>}
      {meta.length > 0 && (
        <div class="meta-row">
          {meta.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      )}
    </div>
    <slot />
  </div>
</section>

<style>
  .content-shell {
    padding: 40px 0 64px;
  }

  .content-main {
    padding: 34px;
  }

  .content-header {
    display: grid;
    gap: 14px;
    margin-bottom: 28px;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-family: var(--font-ui);
    color: var(--muted);
    font-size: 0.92rem;
  }
</style>
