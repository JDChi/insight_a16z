---
interface Props {
  evidence: Array<{
    claim: string;
    evidenceText: string;
    sourceLocator: string;
  }>;
}

const { evidence } = Astro.props;
---

<div class="stack">
  {evidence.map((item) => (
    <article class="evidence-item panel">
      <strong>{item.claim}</strong>
      <p>{item.evidenceText}</p>
      <small>{item.sourceLocator}</small>
    </article>
  ))}
</div>

<style>
  .evidence-item {
    padding: 18px 20px;
  }

  small {
    display: inline-block;
    margin-top: 10px;
    color: var(--muted);
    font-family: var(--font-ui);
  }
</style>
