---
import { toChineseContentType, toChineseTopicName } from "../lib/display";

interface Props {
  article: {
    slug: string;
    zhTitle: string;
    summary: string;
    publishedAt: string;
    contentType: string;
    topics: string[];
  };
}

const { article } = Astro.props;
---

<article class="card panel">
  <div class="meta">
    <span>{toChineseContentType(article.contentType)}</span>
    <span>{article.publishedAt}</span>
  </div>
  <h3><a href={`/articles/${article.slug}`}>{article.zhTitle}</a></h3>
  <p>{article.summary}</p>
  <div class="tags">
    {article.topics.map((topic) => (
      <span>{toChineseTopicName(topic)}</span>
    ))}
  </div>
</article>

<style>
  .card {
    padding: 22px;
    display: grid;
    gap: 14px;
  }

  .meta,
  .tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-ui);
    color: var(--muted);
    font-size: 0.85rem;
  }

  .tags span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.45rem 1rem;
    line-height: 1.1;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    text-align: center;
    white-space: nowrap;
  }
</style>
