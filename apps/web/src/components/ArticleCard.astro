---
import { toChineseContentType, toChineseTopicName } from "../lib/display";

interface Props {
  article: {
    slug: string;
    zhTitle: string;
    summary: string;
    publishedAt: string;
    contentType: string;
    topics: string[];
  };
}

const { article } = Astro.props;
---

<article class="card panel">
  <div class="meta">
    <span class="type-pill">{toChineseContentType(article.contentType)}</span>
    <span>{article.publishedAt}</span>
  </div>
  <h3><a href={`/articles/${article.slug}`}>{article.zhTitle}</a></h3>
  <p class="summary">{article.summary}</p>
  <div class="tags">
    {article.topics.map((topic) => (
      <span>{toChineseTopicName(topic)}</span>
    ))}
  </div>
</article>

<style>
  .card {
    padding: 24px;
    display: grid;
    gap: 15px;
    background: var(--panel-raised);
    border-color: var(--line-strong);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    border-color: rgba(138, 54, 18, 0.24);
  }

  .meta,
  .tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-ui);
    color: var(--muted);
    font-size: 0.85rem;
  }

  h3 {
    font-size: 1.42rem;
    line-height: 1.12;
  }

  h3 a {
    color: var(--text);
  }

  h3 a:hover {
    color: var(--accent-strong);
  }

  .summary {
    margin: 0;
    color: var(--muted-strong);
    display: -webkit-box;
    overflow: hidden;
    line-clamp: 5;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    /*
      Keep cards scannable without forcing masonry: long summaries fade out
      after five lines while the browser still supplies the multiline ellipsis.
    */
    -webkit-mask-image: linear-gradient(180deg, #000 74%, rgba(0, 0, 0, 0));
    mask-image: linear-gradient(180deg, #000 74%, rgba(0, 0, 0, 0));
  }

  .type-pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(182, 77, 19, 0.14), rgba(182, 77, 19, 0.08));
    color: var(--accent-strong);
    font-weight: 600;
  }

  .tags span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.35rem 0.85rem;
    line-height: 1.1;
    border-radius: 999px;
    background: rgba(182, 77, 19, 0.08);
    color: var(--accent-strong);
    text-align: center;
    white-space: nowrap;
  }
</style>
