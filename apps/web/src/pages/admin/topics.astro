---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { isAdminRequest } from "../../lib/admin-auth";
import { toChineseTopicName } from "../../lib/display";
import { getAdminTopics } from "../../lib/content-source";
import AdminShell from "./_components/AdminShell.astro";
import RecordTable from "./_components/RecordTable.astro";

const authorized = isAdminRequest(Astro.request.headers);
const topics = await getAdminTopics();
---

<SiteLayout title="后台专题">
  {authorized ? (
    <AdminShell title="专题队列">
      <RecordTable
        rows={topics.map((topic) => ({
          id: topic.id,
          title: toChineseTopicName(topic.name),
          meta: `${topic.articleCount} 篇文章 · 更新于 ${topic.updatedAt}`,
          status: topic.reviewState
        }))}
      />
    </AdminShell>
  ) : (
    <section class="container" style="padding: 36px 0 72px;">
      <div class="panel" style="padding: 24px;">
        <h1>后台访问受限</h1>
      </div>
    </section>
  )}
</SiteLayout>
