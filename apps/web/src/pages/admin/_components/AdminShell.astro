---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="container admin-shell">
  <div class="panel admin-nav">
    <div>
      <div class="eyebrow">Admin</div>
      <h1>{title}</h1>
    </div>
    <nav>
      <a href="/admin">概览</a>
      <a href="/admin/articles">文章</a>
      <a href="/admin/topics">专题</a>
      <a href="/admin/jobs">任务</a>
    </nav>
  </div>
  <slot />
</section>

<style>
  .admin-shell {
    padding: 36px 0 72px;
    display: grid;
    gap: 24px;
  }

  .admin-nav {
    padding: 24px;
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
  }

  nav {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    font-family: var(--font-ui);
  }
</style>
