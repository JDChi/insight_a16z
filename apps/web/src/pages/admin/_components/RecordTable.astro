---
import StatusBadge from "./StatusBadge.astro";

interface Props {
  rows: Array<{
    id: string;
    title: string;
    meta: string;
    status: string;
    publishAction?: {
      entityType: string;
      entityId: string;
    };
  }>;
}

const { rows } = Astro.props;
---

<div class="panel table-wrap">
  <table>
    <thead>
      <tr>
        <th>标题</th>
        <th>信息</th>
        <th>状态</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <td>{row.title}</td>
          <td>{row.meta}</td>
          <td><StatusBadge status={row.status} /></td>
          <td>
            <div class="actions">
              {row.publishAction && (
                <form method="post" action="/admin/api/actions">
                  <input type="hidden" name="kind" value="publish" />
                  <input type="hidden" name="entityType" value={row.publishAction.entityType} />
                  <input type="hidden" name="entityId" value={row.publishAction.entityId} />
                  <button type="submit">发布</button>
                </form>
              )}
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrap {
    padding: 12px;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    padding: 14px 12px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
  }

  .actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  button {
    padding: 8px 12px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: white;
  }
</style>
