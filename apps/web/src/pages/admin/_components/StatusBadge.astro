---
import { toChineseReviewState } from "../../../lib/display";

interface Props {
  status: string;
}

const { status } = Astro.props;
const tone =
  status === "published" || status === "succeeded"
    ? "success"
    : status === "failed" || status === "rejected"
      ? "danger"
      : status === "reviewing" || status === "running"
        ? "warning"
        : "default";
---

<span class:list={["badge", tone]}>{toChineseReviewState(status)}</span>

<style>
  .badge {
    display: inline-flex;
    padding: 4px 10px;
    border-radius: 999px;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    background: rgba(32, 25, 19, 0.08);
  }

  .success {
    background: rgba(22, 101, 52, 0.12);
    color: var(--success);
  }

  .warning {
    background: rgba(146, 64, 14, 0.12);
    color: var(--warning);
  }

  .danger {
    background: rgba(153, 27, 27, 0.12);
    color: var(--danger);
  }
</style>
