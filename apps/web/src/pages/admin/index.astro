---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getAdminEmail, isAdminRequest } from "../../lib/admin-auth";
import { getAdminOverview, getJobs } from "../../lib/content-source";
import AdminShell from "./_components/AdminShell.astro";
import TaskTable from "./_components/TaskTable.astro";

const authorized = isAdminRequest(Astro.request.headers);
const overview = await getAdminOverview();
const jobs = await getJobs();
---

<SiteLayout title="后台概览">
  {authorized ? (
    <AdminShell title={`后台概览 · ${getAdminEmail(Astro.request.headers)}`}>
      <div class="panel actions-panel">
        <form method="post" action="/admin/api/actions">
          <input type="hidden" name="kind" value="ingest-live" />
          <button type="submit">导入最近一年文章</button>
        </form>
        <form method="post" action="/admin/api/actions">
          <input type="hidden" name="kind" value="process-pending" />
          <button type="submit">处理待分析文章</button>
        </form>
        <form method="post" action="/admin/api/actions">
          <input type="hidden" name="kind" value="rebuild-topics" />
          <button type="submit">重建专题</button>
        </form>
        <form method="post" action="/admin/api/actions">
          <input type="hidden" name="kind" value="rebuild-digest" />
          <button type="submit">生成周报</button>
        </form>
      </div>
      <div class="grid-two">
        <article class="panel metric"><strong>{overview.draftArticles}</strong><span>待分析文章</span></article>
        <article class="panel metric"><strong>{overview.reviewingArticles}</strong><span>分析中文章</span></article>
        <article class="panel metric"><strong>{overview.publishedArticles}</strong><span>已发布文章</span></article>
        <article class="panel metric"><strong>{overview.topicsInReview}</strong><span>处理中专题</span></article>
      </div>
      <TaskTable jobs={jobs} />
    </AdminShell>
  ) : (
    <section class="container" style="padding: 36px 0 72px;">
      <div class="panel" style="padding: 24px;">
        <div class="eyebrow">403</div>
        <h1>后台访问受限</h1>
        <p>请通过 Cloudflare Access 或测试头访问后台。</p>
      </div>
    </section>
  )}
</SiteLayout>

<style>
  .metric {
    padding: 24px;
    display: grid;
    gap: 8px;
  }

  .actions-panel {
    padding: 18px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .actions-panel button {
    padding: 10px 14px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: white;
  }

  strong {
    font-size: 2rem;
    font-family: var(--font-display);
  }

  span {
    color: var(--muted);
    font-family: var(--font-ui);
  }
</style>
