---
import ArticleCard from "../components/ArticleCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { getHomeData } from "../lib/content-source";

const home = await getHomeData();
---

<SiteLayout title="a16z AI 中文洞察站">
  <section class="container page-home stack" style="padding: 36px 0 72px;">
    <section>
      <SectionHeading title="最新文章" description="只展示来自 a16z Articles 的中文分析内容。" href="/articles" />
      <div class="grid-two">
        {home.articles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>

    <section>
      <SectionHeading title="最新投资动态" description="只展示来自 Investment News 的投资与押注信号。" href="/investments" />
      <div class="grid-two">
        {home.investmentNews.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  </section>
</SiteLayout>

<style>
  .page-home {
    gap: 28px;
  }

  @media (max-width: 720px) {
    .page-home {
      gap: 22px;
    }
  }
</style>
