---
import ArticleCard from "../../components/ArticleCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getInvestmentNews } from "../../lib/content-source";

const articles = await getInvestmentNews();
---

<SiteLayout title="投资动态">
  <section class="container" style="padding: 36px 0 72px;">
    <div class="stack">
      <div>
        <h1>投资动态</h1>
        <p>浏览来自 a16z Investment News 的投资、押注与市场信号。</p>
      </div>
      {articles.length > 0 ? (
        <div class="grid-two">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      ) : (
        <EmptyState title="没有匹配结果" description="换个关键词再试试看。" />
      )}
    </div>
  </section>
</SiteLayout>
