---
import ContentLayout from "../../layouts/ContentLayout.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import EmptyState from "../../components/EmptyState.astro";
import EvidenceList from "../../components/EvidenceList.astro";
import { formatBeijingDate, toChineseContentType } from "../../lib/display";
import { getArticleBySlug } from "../../lib/content-source";

const article = await getArticleBySlug(Astro.params.slug ?? "");
---

<SiteLayout title={article ? article.zhTitle : "文章未找到"}>
  {article ? (
    <ContentLayout
      title={article.zhTitle}
      intro={article.summary}
      eyebrow={toChineseContentType(article.contentType)}
    >
      <section class="stack">
        <div class="panel" style="padding: 18px 20px;">
          <div class="eyebrow">来源信息</div>
          <p><strong>发布时间：</strong>{formatBeijingDate(article.publishedAt)}</p>
          <p><strong>英文原标题：</strong>{article.sourceTitle}</p>
          <p><strong>来源：</strong><a href={article.sourceUrl} target="_blank" rel="noreferrer">查看 a16z 原文</a></p>
        </div>

        <div>
          <div class="eyebrow">核心要点</div>
          <ul>
            {article.keyPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>

        <div>
          <div class="eyebrow">关键判断</div>
          <ul>
            {article.keyJudgements.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="panel" style="padding: 18px 20px;">
          <div class="eyebrow">未来推演</div>
          <p><strong>判断：</strong>{article.outlook.statement}</p>
          <p><strong>时间跨度：</strong>{article.outlook.timeHorizon}</p>
          <p><strong>为什么是现在：</strong>{article.outlook.whyNow}</p>
          <p><strong>重点信号：</strong>{article.outlook.signalsToWatch.join("、")}</p>
          <p><strong>置信度：</strong>{article.outlook.confidence === "high" ? "高" : article.outlook.confidence === "medium" ? "中" : "低"}</p>
        </div>

        <div>
          <div class="eyebrow">证据链</div>
          <EvidenceList evidence={article.evidenceLinks} />
        </div>
      </section>
    </ContentLayout>
  ) : (
    <section class="container" style="padding: 36px 0 72px;">
      <EmptyState title="文章未找到" description="这篇文章可能尚未发布，或者链接已发生变化。" />
    </section>
  )}
</SiteLayout>
