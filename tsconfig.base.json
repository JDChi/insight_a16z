{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@insight-a16z/core": [
        "packages/core/src/index.ts"
      ],
      "@insight-a16z/core/*": [
        "packages/core/src/*"
      ]
    }
  }
}
